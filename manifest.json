{
  "manifest_version": 3,
  "name": "Chrome Morph",
  "version": "0.3.0",
  "description": "Tell any page what to do. Press the hotkey, type an instruction or pick a preset, watch it morph.",
  "permissions": ["activeTab", "scripting", "storage", "userScripts"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["config.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["overlay/overlay.css"],
      "matches": ["<all_urls>"]
    }
  ],
  "commands": {
    "toggle-morph": {
      "suggested_key": {
        "default": "Ctrl+J",
        "mac": "Command+J"
      },
      "description": "Open the Morph prompt"
    }
  },
  "action": {
    "default_title": "Open Morph (or use hotkey)",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
